PORT=3000

# Database Configuration (Neon PostgreSQL with PostGIS)
# Get your connection string from: https://console.neon.tech
# Choose AWS Mumbai region for India
DATABASE_URL=postgresql://[user]:[password]@[endpoint].neon.tech/[dbname]?sslmode=require

# Redis Cache
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# SMS Gateway (for phone verification)
# Option 1: Twilio (Free trial)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Option 2: Vonage (Free tier)
# VONAGE_API_KEY=your-vonage-api-key
# VONAGE_API_SECRET=your-vonage-api-secret
# VONAGE_PHONE_NUMBER=your-vonage-phone-number

# Push Notifications
# Option 1: Firebase Cloud Messaging (Free)
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-fcm-project-id

# Option 2: OneSignal (Free tier)
# ONESIGNAL_APP_ID=your-onesignal-app-id
# ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# Weather API
# Option 1: Open-Meteo (Free, no API key required)
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# Option 2: OpenWeatherMap (Free tier: 1000 calls/day)
# OPENWEATHER_API_KEY=your-openweather-api-key
# OPENWEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather

# Routing Service
# OpenStreetMap Routing (OSRM - Free)
OSRM_API_URL=https://router.project-osrm.org

# Mapbox
MAPBOX_ACCESS_TOKEN=your-mapbox-public-token
MAPBOX_SECRET_TOKEN=your-mapbox-secret-token

# Upstash Redis (REST API)
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# Web Dashboard URL (for CORS)
WEB_URL=https://your-web-dashboard.vercel.app
